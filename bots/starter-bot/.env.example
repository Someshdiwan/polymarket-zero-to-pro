# Polymarket Bot — Environment Configuration

# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your values below
#   3. Never commit .env to GitHub (already in .gitignore)


# POLYMARKET API CREDENTIALS

# Where to get:
#   polymarket.com → Connect Wallet → Profile → API Management
#   Click "Create Key" → copy all three values immediately
#   (Secret and Passphrase shown only ONCE — save them now)

POLY_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POLY_API_PASSPHRASE=xxxxxxxxxxxxxxxxxxxx


# WALLET PRIVATE KEY

# Where to get:
#   MetaMask    → Account Details → Export Private Key
#   Trust Wallet → Settings → Wallets → Export Private Key
#
# ⚠️  CRITICAL SECURITY RULES:
#   - Never share this with anyone, ever
#   - Never commit this to GitHub
#   - Use a DEDICATED trading wallet, not your main wallet
#   - Only fund it with what you are willing to trade
#
# Format: 64 hex characters (without 0x prefix)

PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx



# TRADING SETTINGS

# Simulate trades without spending real money
# true  = safe mode, logs what WOULD happen (start here)
# false = live trading with real money
DRY_RUN=true

# Maximum USD per single trade
# Recommended: $2.00 for beginners
# Rule: never exceed 20% of total balance
MAX_BET_SIZE=2.00

# Bot stops all trading if this daily loss is hit
# Recommended: 30% of balance
# Example: $14 balance → set $4.20
DAILY_LOSS_LIMIT=10.00

# Minimum total market volume in USD to consider
# Markets below this threshold are too illiquid to exit cleanly
# Short-term trades  → 100000
# Medium-term trades → 50000
# Long-term holds    → 20000
MIN_MARKET_VOLUME=50000

# Minimum edge required before placing a bet
# Edge = your estimated probability minus market price
# 0.10 = 10% edge required (recommended starting point)
# 0.05 = 5%  (more trades, lower quality signals)
# 0.15 = 15% (fewer trades, higher quality signals)
MIN_EDGE_THRESHOLD=0.10



# NEWS API  (ai-strategy-bot only)

# Where to get:
#   https://newsapi.org → Register free → Dashboard → API Keys
#   Free tier:       100 requests/day
#   Developer tier:  $449/month (unlimited)
#
# Used by news_fetcher.py to pull recent articles per market

NEWS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ANTHROPIC API  (ai-strategy-bot only)

# Where to get:
#   https://console.anthropic.com → API Keys → Create Key
#   Billing: Pay as you go, ~$0.003 per 1K tokens
#   Typical cost per market scan: $0.001 - $0.005
#
# Used by market_analyzer.py to estimate probabilities via Claude

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx



# NETWORK SETTINGS

# Polygon chain ID — do not change
# 137   = Polygon mainnet (use this)
# 80001 = Polygon Mumbai testnet (no real money)
CHAIN_ID=137

# Polymarket CLOB API endpoint — do not change
CLOB_HOST=https://clob.polymarket.com


# LOGGING

# Log verbosity
# DEBUG   → everything, very verbose (use for debugging only)
# INFO    → normal operations (recommended)
# WARNING → only warnings and errors
# ERROR   → only failures
LOG_LEVEL=INFO

# Log file location (relative to bot directory)
LOG_FILE=logs/trades.log
